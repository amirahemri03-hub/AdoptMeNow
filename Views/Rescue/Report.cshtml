@model AdoptMeNow.ViewModels.RescueReportViewModel

@{
    ViewData["Title"] = "Report Rescue";
}

@section Styles {
    <link rel="stylesheet" href="~/css/rescue.css" asp-append-version="true" />
}

<div class="rescue-form-page">

    <!-- Back link -->
    <a asp-controller="Rescue" asp-action="Index" class="rescue-back-link">
        <svg viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
        </svg>
        Back to My Reports
    </a>

    <!-- Page heading -->
    <div class="rescue-form-header">
        <p class="header-eyebrow">Animal Rescue</p>
        <h1>Report a Pet in Need</h1>
        <p>Help us reach an animal — fill in the details and pin the location on the map.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4"
             style="border-radius:9px;font-family:'DM Sans',sans-serif;font-size:.93rem;">
            <svg style="width:18px;height:18px;flex-shrink:0;" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            @TempData["Success"]
        </div>
    }

    <form asp-action="Report" asp-controller="Rescue" method="post" enctype="multipart/form-data">

        <!-- ══ Two-column layout ══ -->
        <div class="rescue-form-layout">

            <!-- ── LEFT: Pet Details ── -->
            <div class="rescue-form-left">

                <!-- Photo panel -->
                <div class="rescue-panel">
                    <div class="rescue-panel-header">
                        <div class="ph-icon">📷</div>
                        <div>
                            <h3>Pet Photo</h3>
                            <p>Upload a clear image of the animal</p>
                        </div>
                    </div>
                    <div class="rescue-panel-body">
                        <div class="rescue-field">
                            <div class="rescue-upload-zone"
                                 ondragover="this.classList.add('dragover')"
                                 ondragleave="this.classList.remove('dragover')"
                                 ondrop="this.classList.remove('dragover')">
                                <input asp-for="ImageFile"
                                       type="file"
                                       accept="image/*"
                                       onchange="previewImage(event)" />
                                <span class="rescue-upload-icon">🐾</span>
                                <p><strong>Click to upload</strong> or drag &amp; drop</p>
                                <p style="font-size:.76rem;margin-top:.2rem;margin-bottom:0;">JPG, PNG, WEBP · max 5 MB</p>
                            </div>
                            <div class="rescue-img-preview" id="imgPreview">
                                <img id="previewImg" src="#" alt="Preview" />
                            </div>
                            <span class="rescue-validation-msg" asp-validation-for="ImageFile"></span>
                        </div>
                    </div>
                </div>

                <!-- Description panel -->
                <div class="rescue-panel">
                    <div class="rescue-panel-header">
                        <div class="ph-icon">📝</div>
                        <div>
                            <h3>Situation Details</h3>
                            <p>Describe what you observed</p>
                        </div>
                    </div>
                    <div class="rescue-panel-body">
                        <div class="rescue-field">
                            <label class="rescue-label" asp-for="Description">Description</label>
                            <textarea class="rescue-textarea"
                                      asp-for="Description"
                                      rows="5"
                                      placeholder="Describe the animal's condition, injury, behaviour, and any other relevant details…"></textarea>
                            <span class="rescue-validation-msg" asp-validation-for="Description"></span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── RIGHT: Location + Submit ── -->
            <div class="rescue-form-right">

                <!-- Location panel -->
                <div class="rescue-panel">
                    <div class="rescue-panel-header">
                        <div class="ph-icon green">📍</div>
                        <div>
                            <h3>Location</h3>
                            <p>Search, click the map, or use GPS</p>
                        </div>
                    </div>
                    <div class="rescue-panel-body">

                        <!-- Detected address (readonly) -->
                        <div class="rescue-field">
                            <label class="rescue-label" asp-for="Location">Detected Address</label>
                            <div class="rescue-input-wrap">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                                </svg>
                                <input asp-for="Location"
                                       id="locationText"
                                       class="rescue-input"
                                       readonly
                                       placeholder="Address will appear after pinning the map…" />
                            </div>
                        </div>

                        <!-- GPS button -->
                        <div class="rescue-field">
                            <button type="button" class="btn-rescue-location" onclick="getCurrentLocation()">
                                <svg viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                                </svg>
                                Use My Current Location
                            </button>
                        </div>

                        <!-- Map search input -->
                        <div class="rescue-field">
                            <label class="rescue-label">Search Location</label>
                            <input id="mapSearch"
                                   class="rescue-input"
                                   placeholder="Search a place or address…" />
                        </div>

                        <!-- Google Map -->
                        <div class="rescue-field" style="margin-bottom:0;">
                            <div id="map" class="rescue-map"></div>
                        </div>

                    </div>
                </div>

                <!-- Submit panel -->
                <div class="rescue-panel">
                    <div class="rescue-panel-body">
                        <button type="submit" class="btn-rescue-submit">
                            <svg viewBox="0 0 20 20" fill="currentColor">
                                <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/>
                            </svg>
                            Submit Rescue Report
                        </button>
                        <p style="font-family:'DM Sans',sans-serif;font-size:.78rem;color:var(--r-muted);text-align:center;margin:.9rem 0 0;">
                            Our team will review your report and follow up within 24 hours.
                        </p>
                    </div>
                </div>

            </div>
        </div>

        <!-- Hidden coords -->
        <input type="hidden" asp-for="Latitude"  id="Latitude"  />
        <input type="hidden" asp-for="Longitude" id="Longitude" />

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAIrCFUEk7IQO_WvzBoh5PfmpEG-wsdZi4&libraries=places&callback=initMap" async defer></script>
    <script>

        /* ── Image preview ── */
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imgPreview').classList.add('active');
            };
            reader.readAsDataURL(file);
        }

        let map, marker, autocomplete;

        window.initMap = function (){

            console.log("MAP INIT STARTED");
            const defaultLocation = { lat: 3.1390, lng: 101.6869 }; // Kuala Lumpur

            map = new google.maps.Map(document.getElementById("map"), {
                center: defaultLocation,
                zoom: 13
            });

            marker = new google.maps.Marker({
                position: defaultLocation,
                map: map,
                draggable: true
            });

            // Autocomplete search
            const input = document.getElementById("mapSearch");
            autocomplete = new google.maps.places.Autocomplete(input);
            autocomplete.bindTo("bounds", map);

            autocomplete.addListener("place_changed", function () {
                const place = autocomplete.getPlace();

                if (!place.geometry) return;

                map.setCenter(place.geometry.location);
                marker.setPosition(place.geometry.location);

                updateLatLng(place.geometry.location);
            });

            // Click on map
            map.addListener("click", function (e) {
                marker.setPosition(e.latLng);
                updateLatLng(e.latLng);
            });

            // Drag marker
            marker.addListener("dragend", function (e) {
                updateLatLng(e.latLng);
            });

        }

        function updateLatLng(location) {

            let lat, lng;

            // Google Maps LatLng object
            if (typeof location.lat === "function") {
                lat = location.lat();
                lng = location.lng();
            }
            // Browser geolocation object
            else {
                lat = location.lat;
                lng = location.lng;
            }

            document.getElementById("Latitude").value = lat;
            document.getElementById("Longitude").value = lng;

            //Reverse geocoding (convert lat/lng → address)
            const geocoder = new google.maps.Geocoder();

            geocoder.geocode({ location: location }, function (results, status) {
                if (status === "OK" && results[0]) {
                    document.getElementById("locationText").value = results[0].formatted_address;
                }
            });
        }

        function getCurrentLocation() {

            if (navigator.geolocation) {

                navigator.geolocation.getCurrentPosition(function (position) {

                    const userLocation = {
                        lat: position.coords.latitude,
                        lng: position.coords.longitude
                    };

                    // Move map + marker
                    map.setCenter(userLocation);
                    marker.setPosition(userLocation);

                    updateLatLng(userLocation);

                }, function (error) {
                    alert("Unable to get location. Please enable GPS.");
                });

            } else {
                alert("Geolocation is not supported by your browser.");
            }
        }

    </script>

}