@model List<Pet>

@{
    ViewData["Title"] = "Manage Pets";
}

<div class="manage-pets-page">

    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-left">
            <span class="page-eyebrow">Admin Panel</span>
            <h1 class="page-title">Manage Pets</h1>
            <p class="page-subtitle">@Model.Count pet(s) currently listed for adoption</p>
        </div>
        <div class="page-header-right">
            <a class="btn-add-pet" asp-controller="Admin" asp-action="AddPet">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                </svg>
                Add New Pet
            </a>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stat-chip">
            <span class="stat-icon">🐶</span>
            <span class="stat-label">Dogs</span>
            <span class="stat-count">@Model.Count(p => p.Category?.ToLower() == "dog")</span>
        </div>
        <div class="stat-chip">
            <span class="stat-icon">🐱</span>
            <span class="stat-label">Cats</span>
            <span class="stat-count">@Model.Count(p => p.Category?.ToLower() == "cat")</span>
        </div>
        <div class="stat-chip">
            <span class="stat-icon">🐾</span>
            <span class="stat-label">Puppy</span>
            <span class="stat-count">@Model.Count(p => p.Category?.ToLower() == "puppy")</span>
        </div>
        <div class="stat-chip">
            <span class="stat-icon">🐾</span>
            <span class="stat-label">Kitten</span>
            <span class="stat-count">@Model.Count(p => p.Category?.ToLower() == "kitten")</span>
        </div>
        <div class="stat-chip stat-chip--total">
            <span class="stat-icon">📋</span>
            <span class="stat-label">Total</span>
            <span class="stat-count">@Model.Count</span>
        </div>
    </div>

    <!-- Pets Table Card -->
    <div class="table-card">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🐾</div>
                <h3>No pets listed yet</h3>
                <p>Start by adding your first pet for adoption.</p>
                <a class="btn-add-pet" asp-controller="Admin" asp-action="AddPet">Add First Pet</a>
            </div>
        }
        else
        {
            <div class="table-scroll">
                <table class="pets-table">
                    <thead>
                        <tr>
                            <th class="col-id">Photo</th>
                            <th class="col-image">Name</th>
                            <th class="col-breed">Breed</th>
                            <th class="col-age">Age</th>
                            <th class="col-gender">Gender</th>
                            <th class="col-category">Category</th>
                            <th class="col-description">Description</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pet in Model)
                        {
                            <tr class="pet-row">
                                <td class="col-image">
                                    @if (!string.IsNullOrEmpty(pet.ImageUrl))
                                    {
                                        <img src="@pet.ImageUrl" alt="@pet.Breed" class="pet-thumb" />
                                    }
                                    else
                                    {
                                        <div class="pet-thumb pet-thumb--placeholder">🐾</div>
                                    }
                                </td>
                                <td class="col-name">
                                    <span class="pet-name">@pet.Name</span>
                                </td>
                                <td class="col-breed">
                                    <span class="breed-name">@pet.Breed</span>
                                </td>
                                <td class="col-age">
                                    <span class="age-badge">@pet.Age yrs</span>
                                </td>
                                <td class="col-gender">
                                    <span class="gender-tag gender-tag">@pet.Gender</span>
                                </td>
                                <td class="col-category">
                                    <span class="category-pill">@pet.Category</span>
                                </td>
                                <td class="col-description">
                                    <span class="desc-text">@pet.Description</span>
                                </td>
                                <td class="col-actions">
                                    <div class="action-group">
                                        <a class="action-btn action-btn--edit"
                                           asp-controller="Admin"
                                           asp-action="EditPet"
                                           @*1*@
                                           asp-route-id="@pet.PetId"
                                           title="Edit">
                                            <svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                                                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                                            </svg>
                                            Edit
                                        </a>
                                        <a class="action-btn action-btn--delete"
                                           asp-controller="Admin"
                                           asp-action="Delete"
                                           asp-route-id="@pet.PetId"
                                           title="Delete"
                                           onclick="return confirm('Are you sure you want to remove @pet.Breed from the listing?')">
                                            <svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                                                <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                             </svg>
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
