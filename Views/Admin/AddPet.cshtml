@model AdoptMeNow.Models.PetDto

@{
    ViewData["Title"] = "Add New Pet";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="add-pet-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb-bar">
        <a class="breadcrumb-link" asp-controller="Admin" asp-action="ManagePets">Manage Pets</a>
        <svg viewBox="0 0 20 20" fill="currentColor" width="13" height="13" class="breadcrumb-chevron">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="breadcrumb-current">Add New Pet</span>
    </div>

    <div class="add-pet-layout">

        <!-- Left: Form Panel -->
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-icon">🐾</div>
                <div>
                    <h1 class="form-title">Add a New Pet</h1>
                    <p class="form-subtitle">Fill in the details below to list a pet for adoption.</p>
                </div>
            </div>

            <form asp-controller="Admin" asp-action="Submit" method="post" enctype="multipart/form-data" class="pet-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <!-- Row 1: Name (full width) -->
                <div class="form-group form-group--full">
                    <label asp-for="Name" class="form-label">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
                        Pet Name
                    </label>
                    <input asp-for="Name" class="form-input" placeholder="e.g. Biscuit, Luna, Max…" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <!-- Row 2: Breed + Age -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Breed" class="form-label">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            Breed
                        </label>
                        <input asp-for="Breed" class="form-input" placeholder="e.g. Golden Retriever" />
                        <span asp-validation-for="Breed" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Age" class="form-label">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
                            Age (years)
                        </label>
                        <input asp-for="Age" type="number" min="0" max="30" class="form-input" placeholder="e.g. 3" />
                        <span asp-validation-for="Age" class="field-error"></span>
                    </div>
                </div>

                <!-- Row 2: Gender + Category -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Gender" class="form-label">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
                            Gender
                        </label>
                        <select asp-for="Gender" class="form-select">
                            <option value="" disabled selected>Select gender</option>
                            <option value="Male">♂ Male</option>
                            <option value="Female">♀ Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Category" class="form-label">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/></svg>
                            Category
                        </label>
                        <select asp-for="Category" class="form-select">
                            <option value="" disabled selected>Select category</option>
                            <option value="Cat">Cat</option>
                            <option value="Kitten">Kitten</option>
                            <option value="Dog">Dog</option>
                            <option value="Puppy">Puppy</option>
                        </select>
                        <span asp-validation-for="Category" class="field-error"></span>
                    </div>
                </div>

                <!-- Description -->
                <div class="form-group form-group--full">
                    <label asp-for="Description" class="form-label">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
                        Description
                    </label>
                    <textarea asp-for="Description" class="form-textarea" rows="4"
                              placeholder="Tell adopters about this pet's personality, habits, and what makes them special…"></textarea>
                    <span asp-validation-for="Description" class="field-error"></span>
                </div>

                <!-- Image Upload -->
                <div class="form-group form-group--full">
                    <label class="form-label">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/></svg>
                        Pet Photo
                    </label>
                    <div class="upload-zone" id="uploadZone">
                        <input asp-for="ImageFile" type="file" id="imageInput" class="upload-input" />
                        <div class="upload-content" id="uploadContent">
                            <div class="upload-icon">📷</div>
                            <p class="upload-text">Click or drag a photo here</p>
                            <p class="upload-hint">JPG, PNG, WEBP — max 5MB</p>
                        </div>
                        <img id="imagePreview" class="upload-preview" src="#" alt="Preview" style="display:none;" />
                    </div>

                    @* If editing, keep existing URL *@
                    <input asp-for="ImageFile" type="hidden" />
                </div>

                <!-- Submit -->
                <div class="form-actions">
                    <a class="btn-cancel" asp-controller="Admin" asp-action="ManagePets">Cancel</a>
                    <button type="submit" class="btn-submit">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Save Pet
                    </button>
                </div>

            </form>
        </div>

        <!-- Right: Tips Panel -->
        <div class="tips-panel">
            <div class="tips-header">
                <span class="tips-icon">💡</span>
                <h3 class="tips-title">Tips for a great listing</h3>
            </div>
            <ul class="tips-list">
                <li>
                    <span class="tip-bullet">📸</span>
                    <span>Use a clear, well-lit photo showing the pet's face and full body.</span>
                </li>
                <li>
                    <span class="tip-bullet">✍️</span>
                    <span>Write a warm, honest description — mention personality, energy level, and any quirks.</span>
                </li>
                <li>
                    <span class="tip-bullet">🎂</span>
                    <span>Double-check the age. Adopters use it to find the right life-stage match.</span>
                </li>
                <li>
                    <span class="tip-bullet">🏷️</span>
                    <span>Pick the most specific category so the right families can find this pet quickly.</span>
                </li>
            </ul>

            <div class="tips-divider"></div>

            <div class="tips-reminder">
                <p>Listings go live immediately after saving. You can edit or remove them at any time from <strong>Manage Pets</strong>.</p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const input = document.getElementById('imageInput');
        const preview = document.getElementById('imagePreview');
        const content = document.getElementById('uploadContent');
        const zone = document.getElementById('uploadZone');

        input.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    content.style.display = 'none';
                };
                reader.readAsDataURL(this.files[0]);
            }
        });

        // Drag-and-drop highlight
        zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            input.files = e.dataTransfer.files;
            input.dispatchEvent(new Event('change'));
        });
    </script>
}
